# Cloudflare D1 (Production only - NOT required for local development)
# CLOUDFLARE_ACCOUNT_ID=""
# CLOUDFLARE_DATABASE_ID=""
# CLOUDFLARE_D1_TOKEN=""

# Local development: Use LOCAL=true to use built-in D1 emulator (no Cloudflare account needed)
# LOCAL=true

ORIGIN="http://localhost:5173"

# Cloudflare Web Analytics (public pages are prerendered, so this must be set at build time)
# Set your Cloudflare Web Analytics token here for the beacon to render on public/blog pages
PUBLIC_CF_WEB_ANALYTICS_TOKEN=""

# Firebase config (used for analytics/feature flags on client side)
# PUBLIC_FIREBASE_CONFIG=""

# Better Auth
# For local dev, any 32+ character string works. For production, generate with high entropy.
# Example: bun -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET="dev-secret-change-me-in-production-abc123"

# --- Self-host (adapter-node) ---
# Runtime adapter: "node" (default) or "cloudflare"
# ADAPTER=node

# Cron secret for /api/admin/cleanup endpoint
# CRON_SECRET=""

# Email notification target for contact form submissions
# CONTACT_NOTIFICATION_EMAIL=""

# Cloudflare Email Service REST (optional - logs to console in dev when absent)
# CF_ACCOUNT_ID=""
# CF_API_TOKEN=""
# EMAIL_FROM=""

# SQLite database path (default: data/vibekit.db)
# DATABASE_PATH="data/vibekit.db"

# Upload storage directory (default: data/uploads, ignored when S3_ENDPOINT is set)
# UPLOAD_DIR="data/uploads"

# S3-compatible storage (RustFS locally, R2 in production)
# When S3_ENDPOINT is set, filesystem storage is bypassed in favor of S3
# S3_ENDPOINT="http://localhost:9000"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_BUCKET="vibekit-media"
# S3_REGION="auto"
